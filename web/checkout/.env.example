# Internal API base URL (used server-side by SvelteKit loader)
API_BASE_URL=https://api.yourservice.com

# OpenPay credentials (public — safe to expose to browser)
PUBLIC_OPENPAY_MERCHANT_ID=your_merchant_id
PUBLIC_OPENPAY_PUBLIC_KEY=your_public_key
PUBLIC_OPENPAY_SANDBOX=false

# Base URL of this checkout service
PUBLIC_CHECKOUT_BASE_URL=https://pay.yourservice.com
